# gpuha orchestrator credentials (copy to .env; .env is gitignored - never commit)
# Milestone 1 (GCP e2-micro stub pool) uses gcloud's own auth (Cloud Shell or
# `gcloud auth login` on the plane) - NO key needed here.
# Milestone 2 (Lambda real-GPU pool):
LAMBDA_API_KEY=
# Optional overrides:
# GPUHA_PLANE_IP=203.0.113.10
# GPUHA_RUNS_DIR=~/gpuha-runs

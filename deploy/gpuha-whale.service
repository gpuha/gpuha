[Unit]
Description=GPU HA fail-whale (graceful OpenAI-shaped degraded endpoint)
After=network.target
[Service]
Type=simple
User=root
WorkingDirectory=/root/gpuha-workbench/gpuha
ExecStart=/usr/bin/python3 whale.py --mode auto --workers 2 --port 8080
Restart=always
RestartSec=3
[Install]
WantedBy=multi-user.target
